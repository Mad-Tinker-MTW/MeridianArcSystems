{
  "name": "meridian-arc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vinext build && node scripts/package-sites.mjs",
    "build:pages": "vite build --config vite.pages.config.js && node scripts/package-pages.mjs",
    "audit:hardening": "node scripts/hardening-audit.mjs",
    "audit:release": "node scripts/release-audit.mjs",
    "start": "vinext start",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "wrangler dev --config dist/server/wrangler.json",
    "deploy:vinext": "vinext-cloudflare deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vinext": "^1.0.0-beta.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@vinext/cloudflare": "^1.0.0-beta.3",
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^8.0.0",
    "wrangler": "^4.113.0"
  }
}
